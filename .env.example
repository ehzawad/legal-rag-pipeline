# Local uv runs can set OPENAI_API_KEY here or in the shell.
# For Docker secret-file mode, leave OPENAI_API_KEY blank and put the key in
# secrets/openai_api_key on the host instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Optional reranking is off by default. To enable it, set
# PIPELINE_RERANK_PROVIDER=cohere and provide either Cohere key variable.
PIPELINE_RERANK_PROVIDER=
COHERE_API_KEY=
CO_API_KEY=

# Cohere rerank defaults to rerank-v4.0-pro. Either variable can override it.
COHERE_RERANK_MODEL=rerank-v4.0-pro
PIPELINE_RERANK_MODEL=

PIPELINE_RETRIEVAL_PROVIDER=openai
PIPELINE_RETRIEVAL_MODE=hybrid
PIPELINE_INDEX_BACKEND=memory
PIPELINE_HYBRID_DENSE_WEIGHT=0.65
PIPELINE_HYBRID_BM25_WEIGHT=0.35
PIPELINE_PLAYBOOK_RISK=true
PIPELINE_PDF_MAX_PAGES=100
PIPELINE_PDF_RENDER_DPI=180
PIPELINE_EXTRACTION_CONFIDENCE_THRESHOLD=0.55
PIPELINE_API_ALLOWED_ROOTS=
